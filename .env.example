# --- ACRCloud (Audio & Video Recognition project) ---
# Create a project at https://console.acrcloud.com -> the host is region-specific,
# e.g. identify-eu-west-1.acrcloud.com or identify-us-west-2.acrcloud.com
ACR_HOST=identify-eu-west-1.acrcloud.com
ACR_ACCESS_KEY=your_acrcloud_access_key
ACR_ACCESS_SECRET=your_acrcloud_access_secret

# --- Spotify (https://developer.spotify.com/dashboard) ---
# Add this exact redirect URI to your Spotify app settings:
#   http://localhost:3000/api/spotify/callback
SPOTIFY_CLIENT_ID=your_spotify_client_id
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret
SPOTIFY_REDIRECT_URI=http://localhost:3000/api/spotify/callback

# Public client id (exposed to the browser; same value as SPOTIFY_CLIENT_ID).
NEXT_PUBLIC_SPOTIFY_CLIENT_ID=your_spotify_client_id
